<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

      <link name="base_footprint" />

      <link name="base_link">
        <inertial>
          <origin xyz="0.00015649276754231247 -1.5202413949868906e-20 0.02525516987016914" rpy="0 0 0"/>
          <mass value="2.0198106425915117"/>
          <inertia ixx="0.000987" iyy="0.002574" izz="0.003244" ixy="-0.0" iyz="0.0" ixz="-1.5e-05"/>
        </inertial>
        <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="silver"/>
        </visual>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
          </geometry>
        </collision>
      </link>
      
      <link name="lidar_link">
        <inertial>
          <origin xyz="4.3119310248057596e-07 -4.421365884183054e-18 0.003499999999999996" rpy="0 0 0"/>
          <mass value="0.009710466542705201"/>
          <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="0.0" iyz="0.0" ixz="-0.0"/>
        </inertial>
        <visual>
          <origin xyz="-0.027035 0.0 -0.05" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/lidar_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="silver"/>
        </visual>
        <collision>
          <origin xyz="-0.027035 0.0 -0.05" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/lidar_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
        </collision>
      </link>
      
      <link name="camera_link">
        <inertial>
          <origin xyz="-2.2124375007731567e-07 -4.225376316804157e-18 0.0025000000000000022" rpy="0 0 0"/>
          <mass value="0.00785"/>
          <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="-0.0" iyz="0.0" ixz="0.0"/>
        </inertial>
        <visual>
          <origin xyz="-0.043496 0.0 -0.042" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/camera_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="silver"/>
        </visual>
        <collision>
          <origin xyz="-0.043496 0.0 -0.042" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/camera_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
        </collision>
      </link>
      
      <link name="left_wheel_link">
        <inertial>
          <origin xyz="-3.469446951953614e-17 0.005000000000000053 -6.938893903907228e-18" rpy="0 0 0"/>
          <mass value="0.1541343895667492"/>
          <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="-0.0" iyz="-0.0" ixz="0.0"/>
        </inertial>
        <visual>
          <origin xyz="0.035 -0.04 -0.025" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/left_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="silver"/>
        </visual>
        <collision>
          <origin xyz="0.035 -0.04 -0.025" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/left_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
        </collision>
      </link>
      
      <link name="right_wheel_link">
        <inertial>
          <origin xyz="-3.469446951953614e-17 -0.005000000000000053 -6.938893903907228e-18" rpy="0 0 0"/>
          <mass value="0.1541343895667492"/>
          <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="0.0" iyz="0.0" ixz="0.0"/>
        </inertial>
        <visual>
          <origin xyz="0.035 0.04 -0.025" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/right_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="silver"/>
        </visual>
        <collision>
          <origin xyz="0.035 0.04 -0.025" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/right_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
        </collision>
      </link>
      
      <link name="caster_wheel_link">
        <inertial>
          <origin xyz="0.04000000000000004 -1.7654107985457012e-18 -0.00375" rpy="0 0 0"/>
          <mass value="0.016441001553786586"/>
          <inertia ixx="0.0" iyy="0.0" izz="1e-06" ixy="-0.0" iyz="0.0" ixz="0.0"/>
        </inertial>
        <visual>
          <origin xyz="-0.0 -0.0 -0.01" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/caster_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="silver"/>
        </visual>
        <collision>
          <origin xyz="-0.0 -0.0 -0.01" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find acc_robotics_description)/meshes/caster_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
        </collision>
      </link>

      <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </joint>
      
      <joint name="base_lidar_joint" type="fixed">
        <origin xyz="0.027035 0.0 0.05" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="lidar_link"/>
      </joint>
      
      <joint name="base_camera_joint" type="fixed">
        <origin xyz="0.043496 0.0 0.042" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="camera_link"/>
      </joint>
      
      <joint name="base_left_wheel_joint" type="continuous">
        <origin xyz="-0.035 0.04 0.025" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <axis xyz="0.0 1.0 0.0"/>
      </joint>
      
      <joint name="base_right_wheel_joint" type="continuous">
        <origin xyz="-0.035 -0.04 0.025" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <axis xyz="-0.0 1.0 0.0"/>
      </joint>
      
      <joint name="base_caster_joint" type="fixed">
        <origin xyz="0.0 0.0 0.01" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="caster_wheel_link"/>
      </joint>

</robot>